# ==========
# AI Provider
# ==========
# Your OpenAI-compatible API key
YUNWU_API_KEY=your_api_key_here

# OpenAI-compatible base URL and model
OPENAI_BASE_URL=https://yunwu.ai/v1
OPENAI_MODEL=gpt-5-mini

# ============
# AnkiConnect
# ============
# Keep default unless you changed AnkiConnect port/address
ANKI_CONNECT_URL=http://localhost:8765

# Target deck/model in Anki
ANKI_DECK_NAME=AI Vocabulary
ANKI_MODEL_NAME=AI Vocabulary Note

# =========
# Edge TTS
# =========
TTS_VOICE=en-US-AriaNeural
